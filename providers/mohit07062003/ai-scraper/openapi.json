        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "targetUrl",
                  "schema"
                ],
                "properties": {
                  "targetUrl": {
                    "type": "string",
                    "format": "uri",
                    "description": "The full URL of the page to extract data from.",
                    "example": "https://books.toscrape.com"
                  },
                  "schema": {
                    "type": "object",
                    "description": "Object mapping field names to expected types or descriptions. Fields not found on the page are returned as null.",
                    "example": {
                      "title": "string",
                      "price": "number",
                      "inStock": "boolean"
                    }
                  }
                }
              },
              "example": {
                "targetUrl": "https://books.toscrape.com",
                "schema": {
                  "title": "string",
                  "price": "number",
                  "inStock": "boolean"
                }
