                      "description": "Extracted page title, if detected",
                      "nullable": true
                    },
                    "data": {
                      "type": "object",
                      "description": "Extracted data matching your requested schema. Fields not found are null."
                    }
                  }
                },
                "example": {
                  "success": true,
                  "title": "A Light in the Attic",
                  "data": {
                    "title": "A Light in the Attic",
                    "price": 51.77,
                    "inStock": true
                  }
                }
              }
            }
