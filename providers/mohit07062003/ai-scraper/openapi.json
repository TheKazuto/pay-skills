            "in": "header",
            "required": false,
            "description": "x402 v2 payment proof. Base64-encoded JSON containing {x402Version:2, scheme:'exact', network:'solana:5eykt4UsFv8P8NJdTREpY1vzqKqZKvdp', payload:{signature:'<tx_sig>'}}. Omit on the first request to receive the payment challenge. The transaction must be less than 5 minutes old and can only be used once.",
            "schema": {
              "type": "string"
            },
            "example": "eyJ4NDAyVmVyc2lvbiI6Mn0="
          },
          {
            "name": "Payment-Payload",
            "in": "header",
            "required": false,
            "description": "Legacy v0 header — raw Solana transaction signature. Accepted for backward compatibility. Prefer X-PAYMENT for x402 v2 agents.",
            "schema": {
              "type": "string"
            }
